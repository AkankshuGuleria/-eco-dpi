# ================================================================
# ECO-DPI ENVIRONMENT VARIABLES TEMPLATE (.env.example)
# Copy these key names into Vercel Dashboard -> Project Settings -> Environment Variables
# ================================================================

# 1. MongoDB Connection String (Required)
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.example.mongodb.net/eco-dpi?retryWrites=true&w=majority

# 2. JWT Secret Key (Required, production must be 32+ random characters)
JWT_SECRET=

# 3. Default Admin Email (Optional)
ADMIN_EMAIL=akankshuguleria2000@gmail.com

# 4. CORS Allowed Origins (Required in production)
CORS_ORIGINS=https://eco-dpi.vercel.app,http://localhost:5173,http://localhost:4173

# 5. Local Server Port (Optional)
PORT=4000

# 6. Frontend API Base URL (Vite)
VITE_API_BASE_URL=/api

# 7. Twilio SMS OTP (Required for production OTP delivery)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=

# 8. Google OAuth (Optional; direct Google login is disabled in production)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
VITE_ALLOW_INSECURE_GOOGLE_DIRECT=false
ALLOW_INSECURE_GOOGLE_DIRECT=false
